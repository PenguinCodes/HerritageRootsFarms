                <h3 class="text-xl font-bold mb-1">WhatsApp</h3>
                <p class="text-gray-700">
                  <a
                    href="https://wa.me/916362745800"
                    target="_blank"
                    class="hover:text-green-600"
                  >
                    +91 6362745800
                  </a>
                </p>
              </div>
            </div>

