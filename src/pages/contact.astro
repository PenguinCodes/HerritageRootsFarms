                <p class="text-gray-700">
                  <a href="tel:+916362745800" class="hover:text-green-600">
                    +91 6362745800
                  </a>
                  <a href="tel:+917483313526" class="hover:text-green-600">
                    +91 7483313526
                  </a>
                </p>
              </div>
            </div>

            <div class="flex items-start">
